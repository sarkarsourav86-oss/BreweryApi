{
  "OpenBreweryDb": {
    "BaseUrl": "https://api.openbrewerydb.org/"
  },
  "Jwt": {
    "Issuer": "BreweryApi",
    "Audience": "BreweryApiClient",
    "SecretKey": "super-secret-key-that-is-at-least-32-characters-long",
    "TokenExpirationMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}